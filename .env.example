# 首次配置建议先跑：openmy skill health.check --json
# 先选转写引擎，再决定要不要配云端 key（密钥）
# 本地转写引擎 faster-whisper / funasr 都可以先跑，不需要任何 key（密钥）

# 可选：如果你想让 Gemini 做蒸馏和提取，再填这个
# GEMINI_API_KEY=your-gemini-api-key

# 可选：显式声明 provider
# OPENMY_STT_PROVIDER=faster-whisper
# OPENMY_LLM_PROVIDER=gemini

# 可选：分别配置模型
# OPENMY_STT_MODEL=gemini-3.1-flash-lite-preview
# OPENMY_LLM_MODEL=gemini-3.1-flash-lite-preview
# OPENMY_EXTRACT_MODEL=gemini-3.1-flash-lite-preview
# OPENMY_DISTILL_MODEL=gemini-3.1-flash-lite-preview

# 可选：分别配置 key（不填时会回退到 GEMINI_API_KEY）
# OPENMY_STT_API_KEY=your-stt-key
# OPENMY_LLM_API_KEY=your-llm-key
